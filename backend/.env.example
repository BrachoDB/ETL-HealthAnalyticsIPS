# ==============================
# Environment variables example
# ==============================

# Development
DEBUG=True

# Security (change this in production)
SECRET_KEY=your-super-secret-key-change-this-in-production-use-32-chars-minimum
JWT_SECRET_KEY=your-jwt-signing-key-must-be-at-least-32-characters-long-for-security

# Hosts allowed
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS local
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Security
OPEN_REGISTRATION=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ==============================
# Database (MySQL - XAMPP localhost)
# User: root | Password: empty
# Port: 3307
# Database: healthanalyticsips_db
# ==============================
DATABASE_URL=mysql://root:@127.0.0.1:3307/healthanalyticsips_db

