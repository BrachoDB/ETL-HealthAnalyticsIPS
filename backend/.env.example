# ==============================================================
# Environment variables example  (copy to backend/.env)
# ==============================================================

# ---- Django core ----
DEBUG=True
SECRET_KEY=change-me-use-a-long-random-secret-key
JWT_SECRET_KEY=your-jwt-signing-key-must-be-at-least-32-characters-long-for-security
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- CORS / CSRF ----
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---- Security (keep False in local; True in production) ----
OPEN_REGISTRATION=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ==============================================================
# Database  (MySQL — keep MySQL in every environment)
# ==============================================================

# ---- LOCAL (XAMPP / local MySQL) ----
# User: root | Password: empty | Port: 3307
DATABASE_URL=mysql://root:@127.0.0.1:3307/healthanalyticsips_db
DB_SSL_REQUIRED=False

# ---- PRODUCTION example (Aiven, SSL REQUIRED) ----
# Set these in the Render dashboard (do NOT commit real credentials):
# DATABASE_URL=mysql://avnadmin:YOUR_PASSWORD@mysql-xxxxx.aivencloud.com:21736/defaultdb
# DB_SSL_REQUIRED=True
# DB_SSL_MODE=REQUIRED
# Optional: verify the server certificate with Aiven's ca.pem
# DB_SSL_CA=/etc/secrets/aiven-ca.pem
